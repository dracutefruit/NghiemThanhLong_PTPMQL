@model GoodsIssue

<h1>Create</h1>

<h4>GoodsIssue</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label for="SupplierId" asp-for="SupplierId" class="control-label"></label>
                <select asp-for="SupplierId" class="form-control" asp-items="@ViewBag.SupplierId"></select>
                <span asp-validation-for="SupplierId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="IssueCode" asp-for="IssueCode" class="control-label"></label>
                <input asp-for="IssueCode" class="form-control" />
                <span asp-validation-for="IssueCode" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="IssueDate" asp-for="IssueDate" class="control-label"></label>
                <input id="IssueDate" value="@DateTime.Now.ToString("dd/MM/yyyy")" class="form-control" readonly />
                <span asp-validation-for="IssueDate" class="text-danger"></span>
            </div>
            <hr>

            <h4>Device</h4>
            <table class="table" id="productTable">
                <tr>
                    <th>DeviceName</th>
                    <th>Quantity</th>
                    <th></th>
                </tr>
            </table>

            <button type="button" onclick="addRow()">+</button>
            <hr>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

<script>
    let index = 0;
    function addRow() {
        let row = `
        <tr>
            <td>
                <select name="GoodsIssueDetails[${index}].DeviceId">
                    ${getDevices()}
                </select>
            </td>
            <td>
                <input type="number" style="width: 70px;" name="GoodsIssueDetails[${index}].Quantity" value="1" min="1"/>
            </td>
            <td>
                <button type="button" onclick="this.closest('tr').remove()">-</button>
            </td>
        </tr>`;

        document.getElementById("productTable").insertAdjacentHTML("beforeend", row);
        index++;
    }

    function getDevices() {
        let options = '';
        @foreach (var p in ViewBag.Devices)
            {
                @:options += `<option value="@p.Id">@p.DeviceName</option>`;
        }
        return options;
    }
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
